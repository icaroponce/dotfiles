[global]
    monitor = 0
    follow = none

    width = 400
    origin = top-right
    offset = 10x32

    indicate_hidden = yes
    shrink = no
    transparency = 0
    separator_height = 2
    padding = 10
    horizontal_padding = 10
    frame_width = 2
    frame_color = "#86abdc"
    separator_color = frame
    corner_radius = 6

    sort = yes
    idle_threshold = 120

    ### Text ###

    font = DejaVu Sans 11
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Icons ###

    icon_position = left
    max_icon_size = 48
    icon_path = /usr/share/icons/Numix/32/status/:/usr/share/icons/Numix/32/devices/:/usr/share/icons/Numix/scalable/status/:/usr/share/icons/Numix/32/actions/:/usr/share/icons/Numix/scalable/devices/

    ### History ###

    sticky_history = yes
    history_length = 20

    ### Misc ###

    dmenu = rofi -dmenu -p dunst
    browser = brave
    always_run_script = true
    title = Dunst
    class = Dunst
    force_xinerama = false

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#192330"
    foreground = "#bbbbbb"
    frame_color = "#192330"
    timeout = 8

[urgency_normal]
    background = "#192330"
    foreground = "#f8f8f2"
    frame_color = "#86abdc"
    timeout = 10

[urgency_critical]
    background = "#192330"
    foreground = "#c94f6d"
    frame_color = "#c94f6d"
    timeout = 0

# vim: ft=cfg
